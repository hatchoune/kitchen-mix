      data: { user },
    } = await supabase.auth.getUser();
    if (!user) return { success: false };

    await supabase
      .from("notifications")
      .update({ read_at: new Date().toISOString() })
      .eq("user_id", user.id)
      .is("read_at", null);

    revalidatePath("/notifications");
    return { success: true };
  } catch (err) {
