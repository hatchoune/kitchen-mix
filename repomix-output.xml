              />
              <select
                value={ing.categorie || ""}
                onChange={(e) => upIng(i, { categorie: e.target.value })}
                className="input-field w-36 text-xs"
              >
                <option value="">Cat.</option>
                {INGREDIENT_CATEGORIES.map((c) => (
