      {/* ── SECTION : Étapes ── */}
      <Section
        title={`Étapes (${etapes.length})`}
        open={openSections.etapes}
        toggle={() => toggleSection("etapes")}
      >
        <div className="space-y-4">
          {etapes.map((et, i) => (
            <div
