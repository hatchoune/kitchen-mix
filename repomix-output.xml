          <div className="glass-card p-4 rounded-2xl border border-border">
            <div className="flex flex-wrap gap-3">
              {achievements.map((a) => (
                <AchievementBadge
                  key={a.achievement_code}
                  code={a.achievement_code}
                  unlocked_at={a.unlocked_at}
                  size="md"
                />
              ))}
            </div>
          </div>
        </div>
