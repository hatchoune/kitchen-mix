      )}

      {/* ── Utilisateurs bannis ── */}
      {tab === "banned" && (
        <div className="grid gap-3">
          {bannedUsers.length === 0 ? (
            <EmptyState msg="Aucun utilisateur banni" />
          ) : (
            bannedUsers.map((b) => (
              <div
                key={b.id}
                className="glass-card p-4 flex items-center justify-between border-l-4 border-error"
              >
                <div className="min-w-0 flex-1">
