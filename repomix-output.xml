  --color-border: rgba(0, 0, 0, 0.08);
  --color-glass: rgba(255, 255, 255, 0.8);
  --color-glass-border: rgba(0, 0, 0, 0.06);
  --color-overlay: rgba(0, 0, 0, 0.5);
  --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.06);
  --shadow-hover: 0 8px 40px rgba(0, 0, 0, 0.1);
}

[data-theme="grey"] {
  --color-bg: #2a2a2a;
  --color-text: #e8e8e4;
  --color-accent: #f5a623;
  --color-accent-hover: #e09510;
  --color-muted: #333333;
  --color-muted-text: #9a9a96;
  --color-card: rgba(255, 255, 255, 0.03);
  --color-card-hover: rgba(255, 255, 255, 0.06);
  --color-border: rgba(255, 255, 255, 0.06);
  --color-glass: rgba(255, 255, 255, 0.04);
  --color-glass-border: rgba(255, 255, 255, 0.08);
  --color-overlay: rgba(0, 0, 0, 0.65);
  --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.25);
  --shadow-hover: 0 8px 40px rgba(0, 0, 0, 0.35);
}

/* =============================================================
   BASE STYLES
   ============================================================= */

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  background-color: var(--color-bg);
  color: var(--color-text);
  min-height: 100dvh;
  transition:
    background-color 0.3s ease,
    color 0.3s ease;
}

/* =============================================================
   TYPOGRAPHY
   ============================================================= */

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
}

h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
}
h2 {
  font-size: clamp(1.5rem, 3.5vw, 2.5rem);
}
h3 {
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
}

/* =============================================================
   GLASSMORPHISM
   ============================================================= */

@layer utilities {
  .glass {
    background: var(--color-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-glass-border);
  }

  .glass-card {
    background: var(--color-card);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: var(--shadow-card);
    transition:
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .glass-card:hover {
    background: var(--color-card-hover);
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }
}

/* =============================================================
   SCROLLBAR
   ============================================================= */

::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--color-muted-text);
}

/* =============================================================
   SKELETON ANIMATION
   ============================================================= */

.skeleton {
  background: linear-gradient(
    90deg,
    var(--color-card) 25%,
    var(--color-card-hover) 50%,
    var(--color-card) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
  border-radius: 8px;
}

/* =============================================================
   PRINT STYLES
   ============================================================= */

@media print {
  nav,
  footer,
  .no-print,
  .bottom-nav,
  button {
    display: none !important;
  }

  body {
    background: white !important;
    color: black !important;
    font-size: 12pt;
  }

  h1,
  h2,
  h3 {
    color: black !important;
    page-break-after: avoid;
  }

  .print-only {
    display: block !important;
  }

  a {
    text-decoration: none;
    color: black !important;
  }

  img {
    max-width: 100% !important;
    page-break-inside: avoid;
  }
}

.print-only {
  display: none;
}

/* =============================================================
   FOCUS STYLES (WCAG AA)
   ============================================================= */

:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
  border-radius: 4px;
}

/* =============================================================
   SELECTION
   ============================================================= */

::selection {
  background: var(--color-accent);
  color: #141414;
}
/* =============================================================
   AJOUT À COLLER À LA FIN DE app/globals.css
   (après la section ::selection, tout à la fin du fichier)
   ============================================================= */

/* Champ de formulaire réutilisable */
.input-field {
  width: 100%;
  background-color: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 10px 16px;
  font-size: 0.875rem;
  color: var(--color-text);
  transition: all 0.2s ease;
}

.input-field::placeholder {
  color: var(--color-muted-text);
}

.input-field:focus {
  outline: none;
  box-shadow: 0 0 0 2px rgba(245, 166, 35, 0.3);
  border-color: var(--color-accent);
}

.input-field option {
  background-color: var(--color-bg);
  color: var(--color-text);
}

/* Safe area pour iPhone avec notch */
.pb-safe {
  padding-bottom: env(safe-area-inset-bottom);
}
</file>

