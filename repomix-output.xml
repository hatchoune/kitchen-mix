          <span>
            Étape {step}/{STEPS}
          </span>
          <span>
            {
              [
                "Informations",
                "Ingrédients",
                "Préparation",
                "Médias & FAQ",
                "Résumé",
              ][step - 1]
            }
          </span>
        </div>
        <div className="h-2 bg-card rounded-full overflow-hidden">
          <div
            className="h-full bg-accent rounded-full transition-all duration-500"
