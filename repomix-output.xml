  dark: "Thème sombre",
  light: "Thème clair",
  grey: "Thème gris",
};

export default function ThemeToggle() {
  const { theme, cycleTheme, mounted } = useTheme();

  if (!mounted) {
    return <div className="w-9 h-9 rounded-lg bg-card animate-pulse" />;
  }

  const Icon = ICONS[theme];

  return (
    <button
      onClick={cycleTheme}
