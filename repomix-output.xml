  getRecettesSimilaires,
} from "@/lib/supabase/queries";
import {
  getRecetteMetadata,
  getRecipeJsonLd,
  getBreadcrumbJsonLd,
  safeJsonLd,
} from "@/lib/seo";
import { SITE_URL } from "@/lib/constants";
import { formatDuree, tempsTotal } from "@/lib/utils";
import Badge from "@/components/ui/Badge";
